server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ hostvars['monitor-node']['ansible_host'] }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: suricata
    static_configs:
      - targets: [localhost]
        labels:
          job: suricata
          node: {{ inventory_hostname }}
          __path__: /var/log/suricata/*.json
    pipeline_stages:
      - json:
          expressions:
            event_type: event_type
            alert: alert
            src_ip: src_ip
            dest_ip: dest_ip
      - labels:
          event_type: event_type

  - job_name: crowdsec
    static_configs:
      - targets: [localhost]
        labels:
          job: crowdsec
          node: {{ inventory_hostname }}
          __path__: /var/log/crowdsec/*.log
    pipeline_stages:
      - regex:
          expression: '.*level=(?P<level>\w+).*'
      - labels:
          level: level
